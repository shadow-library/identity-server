{
  "compilerOptions": {
    /** Language and Environment */
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["ES2022"],
    "target": "ES2022",

    /** Type Checking */
    "alwaysStrict": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false,

    /** Modules */
    "baseUrl": ".",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "paths": {
      "@modules/*": ["src/modules/*"],
      "@scripts/*": ["scripts/*"],
      "@server/*": ["src/*"],
      "@shadow-library/auth": ["packages/auth/src/index.ts"],
      "@shadow-library/auth/module": ["packages/auth/src/module/index.ts"],
      "@shadow-library/auth/rp": ["packages/auth/src/rp/index.ts"],
      "@shadow-library/auth/testing": ["packages/auth/src/testing/index.ts"]
    },
    "resolveJsonModule": true,
    "types": ["bun"],

    /** Emit */
    "noEmit": true,

    /** Interop Constraints */
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,

    /** Completeness */
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts", "packages/**/*.ts"]
}
