{
  "name": "@shadow-library/identity",
  "type": "module",
  "version": "0.0.0",
  "description": "description",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "clean": "rm -rf dist logs CHANGELOG.md",
    "verify": "shadow verify",
    "type-check": "bun run tsc && bun run tsc -p client/tsconfig.json",
    "test": "bun test",
    "build": "bun run build:client && shadow build",
    "dev": "bun run --watch src/main.ts",
    "dev:worker": "bun run --watch src/worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:create-template": "bun run scripts/create-template-db.ts",
    "build:client": "bun run scripts/build-client.ts",
    "dev:client": "bun run --watch scripts/build-client.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/shadow-library/identity.git"
  },
  "author": "Leander Paul <leanderpaul97@outlook.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shadow-library/identity/issues"
  },
  "homepage": "https://github.com/shadow-library/identity#readme",
  "devDependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/schibsted-grotesk": "^5.2.8",
    "@fontsource/spline-sans-mono": "^5.2.8",
    "@happy-dom/global-registrator": "^20.10.6",
    "@shadow-library/auth": "workspace:*",
    "@shadow-library/scripts": "0.2.3",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.1",
    "@types/luxon": "^3.7.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/validator": "^13.15.10",
    "drizzle-kit": "^0.31.6",
    "husky": "^9.1.7",
    "type-fest": "^4.41.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@fastify/static": "^10.0.0",
    "@peculiar/x509": "^2.0.0",
    "@shadow-library/app": "2.0.0-alpha.0",
    "@shadow-library/class-schema": "0.5.0-alpha.0",
    "@shadow-library/common": "2.0.0-alpha.1",
    "@shadow-library/fastify": "2.0.0-alpha.0",
    "@shadow-library/modules": "0.7.0-alpha.0",
    "@shadow-library/ui": "^3.2.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "drizzle-orm": "^0.45.0",
    "drizzle-seed": "^0.3.1",
    "fast-xml-parser": "^5.10.0",
    "ioredis": "^5.8.2",
    "luxon": "^3.7.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "ua-parser-js": "^2.0.6",
    "validator": "^13.15.23",
    "xml-crypto": "^6.1.2"
  }
}
