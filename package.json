{
  "name": "@shadow-library/identity",
  "type": "module",
  "version": "0.0.0",
  "description": "description",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "clean": "rm -rf dist logs CHANGELOG.md",
    "lint": "bun run scripts/lint.ts",
    "type-check": "bun run tsc && bun run tsc -p client/tsconfig.json",
    "build": "bun run scripts/build.ts",
    "dev": "bun run --watch src/main.ts",
    "dev:worker": "bun run --watch src/worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:create-template": "bun run scripts/create-template-db.ts",
    "build:client": "bun run scripts/build-client.ts",
    "dev:client": "bun run --watch scripts/build-client.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/shadow-library/identity.git"
  },
  "author": "Leander Paul <leanderpaul97@outlook.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shadow-library/identity/issues"
  },
  "homepage": "https://github.com/shadow-library/identity#readme",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "~9.38.0",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/schibsted-grotesk": "^5.2.8",
    "@fontsource/spline-sans-mono": "^5.2.8",
    "@happy-dom/global-registrator": "^20.10.6",
    "@shadow-library/auth": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.1",
    "@types/luxon": "^3.7.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/parser": "^8.46.2",
    "drizzle-kit": "^0.31.6",
    "eslint": "~9.38.0",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "tsc-alias": "^1.8.16",
    "type-fest": "^4.41.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2"
  },
  "dependencies": {
    "@fastify/static": "^10.0.0",
    "@shadow-library/app": "^1.3.2",
    "@shadow-library/class-schema": "^0.4.3",
    "@shadow-library/common": "^1.6.4",
    "@shadow-library/fastify": "^1.7.1",
    "@shadow-library/modules": "^0.6.0",
    "@shadow-library/ui": "^1.1.1",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "drizzle-orm": "^0.44.7",
    "drizzle-seed": "^0.3.1",
    "ioredis": "^5.8.2",
    "luxon": "^3.7.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "ua-parser-js": "^2.0.6",
    "validator": "^13.15.23"
  }
}
