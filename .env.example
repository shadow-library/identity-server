# Runtime
NODE_ENV=development

# Datastore (owned by @shadow-library/modules DatabaseModule)
DATABASE_POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/shadow_identity
DATABASE_REDIS_URL=redis://localhost:6379
DATABASE_POSTGRES_LAZY_CONNECTION=true
DATABASE_POSTGRES_MAX_CONNECTIONS=10

# Security — required in production; a default is used only in development
SECURITY_MASTER_ENCRYPTION_KEY=

# Platform bootstrap admin — if the password is empty a strong one is generated
# and logged once on first boot
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@shadow-apps.com
AUTH_BOOTSTRAP_ADMIN_PASSWORD=

# Password policy — enable the Have I Been Pwned breach check in production
AUTH_PASSWORD_BREACH_CHECK_ENABLED=false

# Rate limiting — kill switch and infrastructure IP bypass (comma separated)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_IP_ALLOWLIST=

# WebAuthn relying party
AUTH_WEBAUTHN_RP_ID=localhost
AUTH_WEBAUTHN_ORIGIN=http://localhost:8080

# Notifications go to pulse-server via svc:// service discovery (no base URL config). In-cluster it
# resolves to `http://pulse-server`; locally point it at your pulse dev server:
SERVICE_URL_PULSE_SERVER=http://localhost:3000

# OAuth / OIDC issuer identity
OAUTH_ISSUER=https://identity.shadow-apps.com
OAUTH_LOGIN_URL=https://identity.shadow-apps.com/login

# Worker
WORKER_POLL_INTERVAL=5000

# Server
SERVER_PORT=8080
